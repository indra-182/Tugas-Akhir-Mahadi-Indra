<?xml version="1.0" encoding="UTF-8"?>
<project name="SPK-TOPSIS-Indivara-Group-impl" default="default" basedir="..">
    <property file="nbproject/project.properties"/>

    <target name="-init">
        <mkdir dir="${build.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>

    <target name="default" depends="jar" description="Build the application."/>

    <target name="clean" description="Clean build output.">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <target name="compile" depends="-init" description="Compile source code.">
        <javac srcdir="${src.dir}" destdir="${build.classes.dir}" source="${javac.source}" target="${javac.target}" encoding="${source.encoding}" includeantruntime="false">
            <classpath>
                <pathelement path="${javac.classpath}"/>
            </classpath>
        </javac>
        <copy todir="${build.classes.dir}">
            <fileset dir="${src.dir}" excludes="**/*.java"/>
        </copy>
    </target>

    <target name="test-compile" depends="compile" description="Compile unit tests.">
        <mkdir dir="${build.test.classes.dir}"/>
        <javac srcdir="${test.src.dir}" destdir="${build.test.classes.dir}" source="${javac.source}" target="${javac.target}" encoding="${source.encoding}" includeantruntime="false">
            <classpath>
                <pathelement path="${javac.test.classpath}"/>
            </classpath>
        </javac>
    </target>

    <target name="test" depends="test-compile" description="Run JUnit unit tests.">
        <mkdir dir="${build.test.results.dir}"/>
        <junit fork="true" haltonfailure="true" failureproperty="tests.failed" printsummary="yes">
            <classpath>
                <pathelement path="${run.test.classpath}"/>
            </classpath>
            <formatter type="plain" usefile="false"/>
            <batchtest todir="${build.test.results.dir}">
                <fileset dir="${test.src.dir}" includes="**/*Test.java"/>
            </batchtest>
        </junit>
        <fail if="tests.failed" message="JUnit test failure."/>
    </target>

    <target name="jar" depends="compile" description="Create application jar.">
        <jar destfile="${dist.jar}" basedir="${build.classes.dir}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
    </target>

    <target name="run" depends="compile" description="Run application.">
        <java classname="${main.class}" fork="true">
            <classpath>
                <pathelement path="${run.classpath}"/>
            </classpath>
        </java>
    </target>
</project>
